{
  "name": "deimos-vscode",
  "displayName": "deimos",
  "description": "VS Code companion for deimos: project-aware launch and Control Center. https://github.com/dxiv/dxa-deimos/",
  "version": "0.2.8",
  "publisher": "devnull-bootloader",
  "engines": {
    "vscode": "^1.115.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:deimos.start",
    "onCommand:deimos.startInWorkspaceRoot",
    "onCommand:deimos.openDocs",
    "onCommand:deimos.openSetupDocs",
    "onCommand:deimos.openWorkspaceProfile",
    "onCommand:deimos.openControlCenter",
    "onView:deimos.controlCenter"
  ],
  "main": "./src/extension.js",
  "files": [
    "README.md",
    "media/**",
    "src/extension.js",
    "src/presentation.js",
    "src/state.js",
    "themes/**"
  ],
  "contributes": {
    "commands": [
      {
        "command": "deimos.start",
        "title": "deimos: Launch in Terminal",
        "category": "deimos"
      },
      {
        "command": "deimos.startInWorkspaceRoot",
        "title": "deimos: Launch in Workspace Root",
        "category": "deimos"
      },
      {
        "command": "deimos.openDocs",
        "title": "deimos: Open Repository",
        "category": "deimos"
      },
      {
        "command": "deimos.openSetupDocs",
        "title": "deimos: Open Setup Guide",
        "category": "deimos"
      },
      {
        "command": "deimos.openWorkspaceProfile",
        "title": "deimos: Open Workspace Profile",
        "category": "deimos"
      },
      {
        "command": "deimos.openControlCenter",
        "title": "deimos: Open Control Center",
        "category": "deimos"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "deimos",
          "title": "deimos",
          "icon": "media/deimos.svg"
        }
      ]
    },
    "views": {
      "deimos": [
        {
          "id": "deimos.controlCenter",
          "name": "Control Center",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "deimos",
      "properties": {
        "deimos.launchCommand": {
          "type": "string",
          "default": "deimos",
          "description": "Command run in the integrated terminal when launching deimos."
        },
        "deimos.terminalName": {
          "type": "string",
          "default": "deimos",
          "description": "Integrated terminal tab name for deimos sessions."
        },
        "deimos.useOpenAIShim": {
          "type": "boolean",
          "default": false,
          "description": "Optionally set DEIMOS_USE_OPENAI=1 in launched deimos terminals (OpenAI-compatible provider path)."
        }
      }
    },
    "themes": [
      {
        "label": "Deimos Terminal Black",
        "uiTheme": "vs-dark",
        "path": "./themes/Deimos-Terminal-Black.json"
      }
    ]
  },
  "scripts": {
    "test": "bun test ./src/",
    "lint": "node -e \"for (const file of require('node:fs').readdirSync('./src')) { if (file.endsWith('.js')) { require('node:child_process').execFileSync(process.execPath, ['--check', require('node:path').join('src', file)], { stdio: 'inherit' }); } }\"",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "keywords": [
    "deimos",
    "terminal",
    "theme",
    "cli",
    "llm"
  ],
  "homepage": "https://www.npmjs.com/package/@dxa-deimos/cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/dxiv/dxa-deimos"
  },
  "license": "MIT"
}
